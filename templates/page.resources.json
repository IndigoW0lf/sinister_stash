          "settings": {
            "heading": "LGBTQ+ Gun Clubs & Communities",
            "description": "Spaces built for the rest of us."
          }
        },
        "res_pink_pistols": {
          "type": "resource",
          "settings": {
            "name": "Pink Pistols",
            "description": "LGBTQ+ gun rights organization with 45+ chapters nationwide. \"Pick on someone your own caliber.\"",
            "url": "https://www.pinkpistols.org/"
          }
        },
        "res_blazing_sword": {
          "type": "resource",
          "settings": {
            "name": "Operation Blazing Sword",

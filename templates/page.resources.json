          "type": "resource",
          "settings": {
            "name": "Equality In Arms",
            "description": "Orlando's only LGBTQ+ & minority-owned firearms training company. Zero tolerance for microaggressions — all the vibes.",
            "url": "https://www.equalityinarms.com/"
          }
        },
        "res_trigger_warning": {
          "type": "resource",
          "settings": {
            "name": "Trigger Warning Queer & Trans Gun Club",
            "description": "Queer and trans-centered gun club. The name is a deliberate reclamation. Chapters in multiple cities.",
            "url": "https://www.facebook.com/triggerwarninggunclub/"
          }
        },

        "cat_bipoc": {
          "type": "category",
          "settings": {
            "heading": "BIPOC Gun Organizations",
            "description": "The Second Amendment was written for everyone. These orgs are making sure it works that way."
          }
        },
        "res_naaga": {
          "type": "resource",
          "settings": {
            "name": "NAAGA",
            "description": "National African American Gun Association. 75+ chapters, 45,000+ members. The largest and most established safe space for Black gun owners.",

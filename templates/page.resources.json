          "type": "resource",
          "settings": {
            "name": "Armed Women of America",
            "description": "Formerly The Well Armed Woman. Nationwide shooting chapters for women — monthly meetups, training, and gear reviews actually sized for women.",
            "url": "https://armedwomen.org/"
          }
        },

        "cat_mental_health": {
          "type": "category",
          "settings": {
            "heading": "Mental Health & Crisis Resources",
            "description": "For when it gets hard. LGBTQ+ people — particularly trans people — face dramatically elevated rates of suicidal ideation. We're not going to pretend otherwise or bury a hotline number you'll never see. These people pick up."
          }
        },
        "res_988": {
          "type": "resource",
          "settings": {
            "name": "988 Suicide & Crisis Lifeline",
            "description": "Call or text 988. Free, confidential, 24 hours. The national crisis line.",
            "url": "https://988lifeline.org/"
          }
        },
        "res_trevor": {
          "type": "resource",
          "settings": {
            "name": "The Trevor Project",
            "description": "LGBTQ+ crisis support. Call 1-866-488-7386 or text START to 678-678. 24 hours. If you're a queer young person in crisis, these are your people.",
            "url": "https://www.thetrevorproject.org/"
          }
        },
        "res_trans_lifeline": {
          "type": "resource",
          "settings": {
            "name": "Trans Lifeline",
            "description": "Peer support by and for trans people. Call 877-565-8860. Staffed by trans people. No cops dispatched without consent.",
            "url": "https://translifeline.org/"
          }
        },
        "res_crisis_text": {
          "type": "resource",
          "settings": {
            "name": "Crisis Text Line",
            "description": "Text HOME to 741741. Free, 24/7 crisis support over text. For when a phone call isn't an option.",
            "url": "https://www.crisistextline.org/"
          }
        },

        "cat_training": {
          "type": "category",
          "settings": {
            "heading": "Gun Safety & Training",
            "description": "Owning is a responsibility. These orgs help you carry it well."

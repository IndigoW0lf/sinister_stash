        },

        "cat_progressive": {
          "type": "category",
          "settings": {
            "heading": "Left-Leaning & Progressive Gun Orgs",
            "description": "You can own guns and still believe in healthcare. These aren't contradictions."
          }
        },
        "res_sra": {
          "type": "resource",
          "settings": {
            "name": "Socialist Rifle Association",
            "description": "Pro-gun leftist organization with 50+ chapters and 10,000+ members. Community defense, not culture war.",
            "url": "https://socialistra.org/"
          }
        },
        "res_lgc": {
          "type": "resource",
          "settings": {
            "name": "Liberal Gun Club",
            "description": "4,500+ members across 30 state chapters. A pro-2A voice for left-of-center gun owners. Proof the Second Amendment doesn't belong to one party.",
            "url": "https://theliberalgunclub.com/"
          }
        },
        "res_abw2a": {
          "type": "resource",
          "settings": {
            "name": "A Better Way 2A",

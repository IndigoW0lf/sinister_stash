{% comment %}
  Sinister Stash — California AB 1263 restriction notice
  Renders on any product tagged 'ca-restricted'.
  Shows on page load if IP geolocation detects California.
  Also disables the Add to Cart button for CA visitors.
{% endcomment %}

<div class="sg-ca-notice" id="sg-ca-notice" role="alert" aria-live="polite">
  <strong>California customers:</strong> We're working on AB 1263 compliance so we can ship to you legally. Back plates are temporarily unavailable for CA shipping. Stickers, patches, and apparel ship to you no problem — we see you and we're coming.
</div>

<script>
  (function() {
    fetch('/browsing_context_suggestions.json')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var regions = data &&
          data.detected_values &&
          data.detected_values.country_with_regions &&
          data.detected_values.country_with_regions.regions;
        var isCA = regions && regions.some(function(r) {
          return r.handle === 'california';
        });
        if (!isCA) return;

        /* Show the notice */
        var notice = document.getElementById('sg-ca-notice');
        if (notice) notice.style.display = 'block';

        /* Disable Add to Cart */
        var atc = document.querySelector('[name="add"]');
        if (atc) {
          atc.disabled = true;
          atc.textContent = 'Unavailable in California';
          atc.style.opacity = '0.45';
          atc.style.cursor = 'not-allowed';
          atc.style.pointerEvents = 'none';
        }

        /* Hide dynamic checkout buttons (Shop Pay, PayPal etc) */
        var dynamicBtns = document.querySelector('.shopify-payment-button');
        if (dynamicBtns) dynamicBtns.style.display = 'none';
      })
      .catch(function() {
        /* Fail silently — never block a valid purchase on detection failure */
      });
  })();
</script>

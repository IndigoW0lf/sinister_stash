{%- paginate blog.articles by 10 -%}

<div class="ss-blog">
  <div class="ss-blog__inner">

    <header class="ss-blog__header">
      <h1 class="ss-blog__title">{{ blog.title | upcase }}</h1>
    </header>

    <div class="ss-blog__list">
      {%- for article in blog.articles -%}
        <article class="ss-blog__card">

          <div class="ss-blog__card-meta">
            <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
              {{- article.published_at | date: '%B %d, %Y' | upcase -}}
            </time>
            {%- if article.tags.size > 0 -%}
              <span class="ss-blog__card-meta-sep">·</span>
              <span class="ss-blog__card-category">{{ article.tags | first | upcase }}</span>
            {%- endif -%}
          </div>

          <h2 class="ss-blog__card-title">
            <a href="{{ article.url }}">{{ article.title }}</a>
          </h2>

          {%- if article.excerpt.size > 0 -%}
            <p class="ss-blog__card-excerpt">{{ article.excerpt | strip_html }}</p>
          {%- elsif article.content.size > 0 -%}
            <p class="ss-blog__card-excerpt">{{ article.content | strip_html | truncate: 220 }}</p>
          {%- endif -%}

          <a href="{{ article.url }}" class="ss-blog__card-read" aria-label="Read {{ article.title }}">Read →</a>

        </article>
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      {%- render 'pagination', paginate: paginate -%}
    {%- endif -%}

  </div>
</div>
{%- endpaginate -%}

<style>
/* ============================================
   BLOG INDEX — SINISTER
   ============================================ */

.ss-blog {
  background-color: #141E24;
  min-height: 60vh;
  padding: 120px 0 120px;
}

@media screen and (max-width: 749px) {
  .ss-blog {
    padding: 80px 0 80px;
  }
}

.ss-blog__inner {
  max-width: 128rem;
  margin: 0 auto;
  padding: 0 4rem;
}

@media screen and (max-width: 749px) {
  .ss-blog__inner {
    padding: 0 2.4rem;
  }
}

/* ── Header ──────────────────────────────── */

.ss-blog__header {
  margin-bottom: 6.4rem;
  padding-bottom: 0;
}

@media screen and (max-width: 749px) {
  .ss-blog__header {
    margin-bottom: 4rem;
  }
}

.ss-blog__title {
  display: inline-block;
  font-family: var(--font-heading-family);
  font-size: 4.8rem;
  font-weight: 400;
  line-height: 1;
  color: #eef4f0;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  margin: 0;
  padding-bottom: 1.4rem;
  border-bottom: 4px solid #F0645A;
}

@media screen and (min-width: 750px) {
  .ss-blog__title {
    font-size: 7.2rem;
  }
}

/* ── Post List ───────────────────────────── */

.ss-blog__list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

/* ── Post Card ───────────────────────────── */

.ss-blog__card {
  padding: 4.8rem 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
}

.ss-blog__card:first-child {
  border-top: 1px solid rgba(255, 255, 255, 0.08);
}

/* Date + category row */
.ss-blog__card-meta {
  display: flex;
  align-items: center;
  gap: 0;
  font-family: var(--font-body-family);
  font-size: 1.1rem;
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: #4AD4A8;
  margin-bottom: 1.6rem;
}

.ss-blog__card-meta-sep {
  margin: 0 1rem;
  opacity: 0.4;
}

.ss-blog__card-category {
  color: #4AD4A8;
}

/* Post title */
.ss-blog__card-title {
  font-family: var(--font-body-family);
  font-weight: 700;
  font-size: clamp(2.4rem, 4vw, 3.6rem);
  line-height: 1.1;
  color: #eef4f0;
  margin: 0 0 1.6rem;
  max-width: 80rem;
}

.ss-blog__card-title a {
  color: inherit;
  text-decoration: none;
  transition: color 0.15s ease;
}

.ss-blog__card-title a:hover {
  color: #F0645A;
  text-decoration: none;
}

/* Excerpt */
.ss-blog__card-excerpt {
  font-family: var(--font-body-family);
  font-size: 1.7rem;
  line-height: 1.65;
  color: rgba(238, 244, 240, 0.75);
  margin: 0 0 2.4rem;
  max-width: 72rem;
}

/* Read link */
.ss-blog__card-read {
  display: inline-block;
  font-family: var(--font-body-family);
  font-size: 1.3rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #F0645A;
  text-decoration: none;
  transition: color 0.15s ease, letter-spacing 0.15s ease;
}

.ss-blog__card-read:hover {
  color: #eef4f0;
  letter-spacing: 0.14em;
  text-decoration: none;
}

/* ── Pagination ──────────────────────────── */

.ss-blog .pagination {
  margin-top: 6.4rem;
}
</style>

{% schema %}
{
  "name": "Sinister Blog",
  "tag": "section",
  "class": "section",
  "settings": []
}
{% endschema %}

<div class="sg-resources color-{{ section.settings.color_scheme }}">

  <!-- Hero -->
  <div class="sg-resources__hero">
    <div class="page-width">
      <p class="sg-resources__eyebrow">{{ section.settings.eyebrow }}</p>
      <h1 class="sg-resources__title">{{ section.settings.title }}</h1>
      <p class="sg-resources__intro">{{ section.settings.intro }}</p>
    </div>
  </div>

  <!-- Jump Nav -->
  <div class="sg-resources__jump-nav-wrap">
    <div class="page-width">
      <nav class="sg-resources__jump-nav" aria-label="Jump to section">
        {%- for block in section.blocks -%}
          {%- if block.type == 'category' or block.type == 'position_box' -%}
            <a href="#cat-{{ block.settings.heading | handleize }}" class="sg-resources__jump-link">
              {{- block.settings.heading -}}
            </a>
          {%- endif -%}
        {%- endfor -%}
      </nav>
    </div>
  </div>

  <!-- Resource Categories (accordion) -->
  <div class="sg-resources__body page-width">
    {%- assign accordion_open = false -%}
    {%- for block in section.blocks -%}
      {%- case block.type -%}

        {%- when 'category' -%}
          {%- if accordion_open -%}
            </div></details>
          {%- endif -%}
          <details class="sg-resources__accordion" id="cat-{{ block.settings.heading | handleize }}" {{ block.shopify_attributes }}>
            <summary class="sg-resources__accordion-summary">
              <div class="sg-resources__accordion-heading-wrap">
                <h2 class="sg-resources__category-title">{{ block.settings.heading }}</h2>
                {%- if block.settings.description != blank -%}
                  <p class="sg-resources__category-desc">{{ block.settings.description }}</p>
                {%- endif -%}
              </div>
              <span class="sg-resources__accordion-icon" aria-hidden="true"></span>
            </summary>
            <div class="sg-resources__accordion-body">
          {%- assign accordion_open = true -%}

        {%- when 'resource' -%}
          <a href="{{ block.settings.url }}" target="_blank" rel="noopener noreferrer" class="sg-resources__card" {{ block.shopify_attributes }}>
            <div class="sg-resources__card-content">
              <h3 class="sg-resources__card-name">{{ block.settings.name }}</h3>
              <p class="sg-resources__card-desc">{{ block.settings.description }}</p>
            </div>
            <span class="sg-resources__card-arrow" aria-hidden="true">&rarr;</span>
          </a>

        {%- when 'position_box' -%}
          {%- if accordion_open -%}
            </div></details>
            {%- assign accordion_open = false -%}
          {%- endif -%}
          <div class="sg-resources__position-box" id="cat-{{ block.settings.heading | handleize }}" {{ block.shopify_attributes }}>
            <h2 class="sg-resources__position-heading">{{ block.settings.heading }}</h2>
            <div class="sg-resources__position-content">{{ block.settings.content }}</div>
          </div>

      {%- endcase -%}
    {%- endfor -%}
    {%- if accordion_open -%}
      </div></details>
    {%- endif -%}

    <!-- CTA -->
    <div class="sg-resources__cta">
      <p class="sg-resources__cta-text">{{ section.settings.cta_text }}</p>
      {%- if section.settings.cta_button_label != blank -%}
        <a href="{{ section.settings.cta_link }}" class="button button--primary">
          {{ section.settings.cta_button_label }} &rarr;
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

<script>
  document.querySelectorAll('.sg-resources__jump-link').forEach(function(link) {
    link.addEventListener('click', function() {
      var id = this.getAttribute('href').slice(1);
      var target = document.getElementById(id);
      if (target && target.tagName === 'DETAILS') {
        target.setAttribute('open', '');
      }
    });
  });
</script>

<style>
  .sg-resources {
    background-color: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
  }

  /* Hero */
  .sg-resources__hero {
    padding: 6rem 2.4rem 4rem;
    text-align: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .sg-resources__eyebrow {
    font-family: var(--font-body-family);
    font-size: 1.3rem;
    font-weight: 400;
    color: rgb(var(--color-coral));
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 2rem;
  }

  .sg-resources__title {
    font-family: var(--font-heading-family);
    font-size: 4.2rem;
    line-height: 1.0;
    text-transform: uppercase;
    color: rgb(var(--color-ice-white));
    margin-bottom: 2rem;
  }

  @media screen and (min-width: 750px) {
    .sg-resources__hero {
      padding: 10rem 2.4rem 6rem;
    }
    .sg-resources__title {
      font-size: 7.2rem;
    }
  }

  .sg-resources__intro {
    font-family: var(--font-body-family);
    font-size: 1.6rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.7);
    max-width: 64rem;
    margin: 0 auto;
  }

  @media screen and (min-width: 750px) {
    .sg-resources__intro {
      font-size: 1.8rem;
    }
  }

  /* Jump Nav */
  .sg-resources__jump-nav-wrap {
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    padding: 2rem 0;
    position: sticky;
    top: 0;
    z-index: 10;
    background-color: rgb(var(--color-background));
  }

  .sg-resources__jump-nav {
    display: flex;
    gap: 0.8rem;
    overflow-x: auto;
    padding-bottom: 0.4rem;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .sg-resources__jump-nav::-webkit-scrollbar {
    display: none;
  }

  .sg-resources__jump-link {
    display: inline-block;
    flex-shrink: 0;
    padding: 0.6rem 1.4rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    font-family: var(--font-body-family);
    font-size: 1.3rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    white-space: nowrap;
    transition: border-color 0.15s ease, color 0.15s ease, background-color 0.15s ease;
  }

  .sg-resources__jump-link:hover {
    border-color: rgb(var(--color-coral));
    color: rgb(var(--color-coral));
    background-color: rgba(var(--color-coral), 0.06);
  }

  /* Body */
  .sg-resources__body {
    padding-top: 2rem;
    padding-bottom: 8rem;
  }

  /* Accordion */
  .sg-resources__accordion {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .sg-resources__accordion:last-of-type {
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .sg-resources__accordion-summary {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2.4rem;
    padding: 3.6rem 0;
    cursor: pointer;
    list-style: none;
  }

  .sg-resources__accordion-summary::-webkit-details-marker {
    display: none;
  }

  .sg-resources__accordion-heading-wrap {
    flex: 1;
  }

  .sg-resources__category-title {
    font-family: var(--font-heading-family);
    font-size: 2.8rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: rgb(var(--color-ice-white));
    margin-bottom: 0.4rem;
    transition: color 0.15s ease;
  }

  .sg-resources__accordion-summary:hover .sg-resources__category-title {
    color: rgb(var(--color-coral));
  }

  @media screen and (min-width: 750px) {
    .sg-resources__category-title {
      font-size: 3.6rem;
    }
  }

  .sg-resources__category-desc {
    font-family: var(--font-body-family);
    font-size: 1.5rem;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.6;
    max-width: 56rem;
    margin: 0;
  }

  /* +/– icon */
  .sg-resources__accordion-icon {
    flex-shrink: 0;
    width: 2.4rem;
    height: 2.4rem;
    margin-top: 0.6rem;
    position: relative;
    color: rgba(255, 255, 255, 0.3);
    transition: color 0.15s ease;
  }

  .sg-resources__accordion-icon::before,
  .sg-resources__accordion-icon::after {
    content: '';
    position: absolute;
    background: currentColor;
    border-radius: 1px;
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  .sg-resources__accordion-icon::before {
    width: 100%;
    height: 2px;
    top: 50%;
    left: 0;
    transform: translateY(-50%);
  }

  .sg-resources__accordion-icon::after {
    width: 2px;
    height: 100%;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
  }

  .sg-resources__accordion[open] .sg-resources__accordion-icon {
    color: rgb(var(--color-coral));
  }

  .sg-resources__accordion[open] .sg-resources__accordion-icon::after {
    opacity: 0;
    transform: translateX(-50%) rotate(90deg);
  }

  .sg-resources__accordion-body {
    padding-bottom: 3.2rem;
  }

  /* Resource cards */
  .sg-resources__card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2.4rem;
    padding: 2.4rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    text-decoration: none !important;
    color: inherit;
    transition: padding-left 0.2s ease;
  }

  .sg-resources__card:hover {
    padding-left: 1.2rem;
  }

  .sg-resources__card:hover .sg-resources__card-name {
    color: rgb(var(--color-coral));
  }

  .sg-resources__card:hover .sg-resources__card-arrow {
    color: rgb(var(--color-coral));
    transform: translateX(4px);
  }

  .sg-resources__card-content {
    flex: 1;
    min-width: 0;
  }

  .sg-resources__card-name {
    font-family: var(--font-body-family);
    font-weight: 700;
    font-size: 1.7rem;
    color: rgb(var(--color-ice-white));
    margin-bottom: 0.4rem;
    transition: color 0.2s ease;
  }

  .sg-resources__card-desc {
    font-family: var(--font-body-family);
    font-size: 1.4rem;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.5;
  }

  .sg-resources__card-arrow {
    font-size: 2rem;
    color: rgba(255, 255, 255, 0.25);
    flex-shrink: 0;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  /* Our Position box */
  .sg-resources__position-box {
    margin-top: 6.4rem;
    padding: 4rem 4.8rem;
    border-left: 3px solid rgb(var(--color-coral));
    background-color: rgba(255, 255, 255, 0.03);
  }

  .sg-resources__position-heading {
    font-family: var(--font-heading-family);
    font-size: 2.4rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgb(var(--color-coral));
    margin-bottom: 2rem;
  }

  .sg-resources__position-content p {
    font-family: var(--font-body-family);
    font-size: 1.6rem;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 1.6rem;
  }

  .sg-resources__position-content p:last-child {
    margin-bottom: 0;
  }

  @media screen and (min-width: 750px) {
    .sg-resources__position-content p {
      font-size: 1.7rem;
    }
  }

  /* Bottom CTA */
  .sg-resources__cta {
    margin-top: 6.4rem;
    padding: 4.8rem;
    background-color: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    text-align: center;
  }

  .sg-resources__cta-text {
    font-family: var(--font-body-family);
    font-size: 1.8rem;
    font-weight: 700;
    color: rgb(var(--color-ice-white));
    margin-bottom: 2rem;
  }
</style>

{% schema %}
{
  "name": "Resources Page",
  "class": "sg-resources-section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "SINISTER STASH"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Page title",
      "default": "Resources"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro text",
      "default": "The organizations, resources, and honest information gun culture never gave you."
    },
    {
      "type": "textarea",
      "id": "cta_text",
      "label": "Bottom CTA text",
      "default": "Know an organization we should include? We're always listening."
    },
    {
      "type": "text",
      "id": "cta_button_label",
      "label": "CTA button label",
      "default": "GET IN TOUCH"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA button link"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category Heading",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Category title",
          "default": "Category Name"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Category description",
          "default": "A short description of this category."
        }
      ]
    },
    {
      "type": "resource",
      "name": "Resource Link",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Organization name",
          "default": "Organization Name"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "A short description of the organization."
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link URL"
        }
      ]
    },
    {
      "type": "position_box",
      "name": "Our Position Box",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Our Position"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Resources Page"
    }
  ],
  "max_blocks": 80
}
{% endschema %}

{% comment %}
  Sinister Stash — Email Signup Popup
  Shows once per visitor via cookie. Collects email for newsletter.
{% endcomment %}

{{ 'sinister-popup.css' | asset_url | stylesheet_tag }}

<div id="sg-popup-overlay" class="sg-popup-overlay" style="display:none;" role="dialog" aria-modal="true" aria-label="Email signup">
  <div class="sg-popup">
    <button class="sg-popup__close" aria-label="Close popup" onclick="sgClosePopup()">&times;</button>

    <div class="sg-popup__border-accent"></div>

    <div class="sg-popup__content">
      <p class="sg-popup__eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="sg-popup__headline">{{ section.settings.headline }}</h2>
      <p class="sg-popup__subhead">{{ section.settings.subhead }}</p>

      <div class="sg-popup__form-wrapper" id="sg-popup-form-wrapper">
        <form id="sg-popup-form" action="/contact#contact_form" method="POST" novalidate>
          <input type="hidden" name="form_type" value="customer">
          <input type="hidden" name="utf8" value="✓">
          <input type="hidden" name="contact[tags]" value="popup,welcome-offer">
          <div class="sg-popup__field-row">
            <input
              type="email"
              name="contact[email]"
              id="sg-popup-email"
              placeholder="YOUR EMAIL"
              required
              aria-required="true"
              class="sg-popup__input"
              aria-label="Email address"
              aria-describedby="sg-popup-error"
              autocomplete="email"
            >
            <button type="submit" class="sg-popup__submit" id="sg-popup-btn">
              {{ section.settings.button_label }}
            </button>
          </div>
          <p id="sg-popup-error" class="sg-popup__error" role="alert" style="display:none;"></p>
        </form>
      </div>

      <p class="sg-popup__code-hint">{{ section.settings.code_hint }}</p>
      <p class="sg-popup__fine-print">{{ section.settings.fine_print }}</p>
    </div>

    <div class="sg-popup__border-accent sg-popup__border-accent--bottom"></div>
  </div>
</div>

<script>
  (function() {
    var COOKIE_NAME = 'sg_popup_seen';
    var DELAY_MS = {{ section.settings.delay_seconds | times: 1000 }};
    var COOKIE_DAYS = {{ section.settings.cookie_days }};
    var DISCOUNT_CODE = '{{ section.settings.discount_code }}';
    var DISCOUNT_AMT = '{{ section.settings.discount_amount }}';

    function getCookie(name) {
      var match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
      return match ? match[2] : null;
    }

    function setCookie(name, value, days) {
      var d = new Date();
      d.setTime(d.getTime() + (days * 24 * 60 * 60 * 1000));
      document.cookie = name + '=' + value + ';expires=' + d.toUTCString() + ';path=/;SameSite=Lax';
    }

    /* Show popup after delay if not seen */
    if (!getCookie(COOKIE_NAME)) {
      setTimeout(function() {
        var overlay = document.getElementById('sg-popup-overlay');
        if (overlay) {
          overlay.style.display = 'flex';
          document.body.style.overflow = 'hidden';
        }
      }, DELAY_MS);
    }

    /* Copy discount code to clipboard */
    window.sgCopyCode = function(el) {
      navigator.clipboard.writeText(DISCOUNT_CODE).then(function() {
        el.setAttribute('data-copied', 'true');
        el.textContent = 'COPIED!';
        setTimeout(function() {
          el.textContent = DISCOUNT_CODE;
          el.removeAttribute('data-copied');
        }, 1500);
      });
    };

    /* Close popup */
    window.sgClosePopup = function() {
      var overlay = document.getElementById('sg-popup-overlay');
      if (overlay) {
        overlay.style.display = 'none';
        document.body.style.overflow = '';
        setCookie(COOKIE_NAME, '1', COOKIE_DAYS);
      }
    };

    /* Close on overlay click */
    document.addEventListener('click', function(e) {
      if (e.target && e.target.id === 'sg-popup-overlay') {
        window.sgClosePopup();
      }
    });

    /* Close on Escape key */
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') window.sgClosePopup();
    });

    /* Show success state */
    function showSuccess() {
      var content = document.querySelector('.sg-popup__content');
      if (content) {
        content.innerHTML =
          '<p class="sg-popup__eyebrow">YOU\'RE IN.</p>' +
          '<h2 class="sg-popup__headline">WELCOME TO<br>THE STASH.</h2>' +
          '<p class="sg-popup__subhead sg-popup__subhead--tight">Use code at checkout for ' + DISCOUNT_AMT + ' off your first order.</p>' +
          '<div class="sg-popup__code" onclick="sgCopyCode(this)" title="Click to copy">' + DISCOUNT_CODE + '</div>' +
          '<button class="sg-popup__submit" onclick="sgClosePopup()">START SHOPPING</button>';
      }
      setCookie(COOKIE_NAME, '1', COOKIE_DAYS);
    }

    /* Intercept form submit — MUST prevent default before anything else */
    document.addEventListener('submit', function(e) {
      var form = document.getElementById('sg-popup-form');
      if (!form || e.target !== form) return;

      /* Stop the form from navigating — this is the critical line */
      e.preventDefault();
      e.stopPropagation();
      e.stopImmediatePropagation();

      var emailInput = document.getElementById('sg-popup-email');
      var email = emailInput ? emailInput.value.trim() : '';

      /* Basic validation */
      var errorEl = document.getElementById('sg-popup-error');
      if (!email || email.indexOf('@') === -1 || email.indexOf('.') === -1) {
        emailInput.style.borderColor = '#F0645A';
        if (errorEl) {
          errorEl.textContent = 'Please enter a valid email address.';
          errorEl.style.display = 'block';
        }
        return;
      }

      /* Clear any prior error */
      if (errorEl) {
        errorEl.style.display = 'none';
        errorEl.textContent = '';
      }
      emailInput.style.borderColor = '';

      /* Disable button and show loading */
      var btn = document.getElementById('sg-popup-btn');
      if (btn) {
        btn.textContent = 'JOINING...';
        btn.disabled = true;
      }

      /* Send to Shopify via fetch — no page navigation */
      var body = new URLSearchParams();
      body.append('form_type', 'customer');
      body.append('utf8', '\u2713');
      body.append('contact[email]', email);
      body.append('contact[tags]', 'popup,welcome-offer');

      fetch('/contact#contact_form', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded',
          'Accept': 'application/json'
        },
        body: body.toString()
      })
      .then(function(response) {
        if (!response.ok && response.status !== 302) {
          throw new Error('Signup failed');
        }
        showSuccess();
      })
      .catch(function(err) {
        /* Shopify contact forms often redirect (302) which fetch treats as an error.
           If the request was made, the email was likely saved. */
        if (err.message === 'Signup failed') {
          if (errorEl) {
            errorEl.textContent = 'Something went wrong. Please try again.';
            errorEl.style.display = 'block';
          }
          if (btn) {
            btn.textContent = '{{ section.settings.button_label }}';
            btn.disabled = false;
          }
        } else {
          showSuccess();
        }
      });

      return false;
    }, true); /* <-- capture phase: fires BEFORE Shopify's handlers */

  })();
</script>

{% schema %}
{
  "name": "Email Popup",
  "class": "sg-popup-section",
  "limit": 1,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "SINISTER STASH"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "GET 10% OFF YOUR FIRST ORDER."
    },
    {
      "type": "textarea",
      "id": "subhead",
      "label": "Subhead",
      "default": "New drops. First access. No spam. Just the culture we're building."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "I'M IN →"
    },
    {
      "type": "text",
      "id": "discount_code",
      "label": "Discount code to show after signup",
      "default": "LOADUP10"
    },
    {
      "type": "text",
      "id": "discount_amount",
      "label": "Discount description",
      "default": "10%"
    },
    {
      "type": "text",
      "id": "code_hint",
      "label": "Code hint below form",
      "default": "Your code arrives instantly. No waiting."
    },
    {
      "type": "text",
      "id": "fine_print",
      "label": "Fine print",
      "default": "Unsubscribe anytime. We're not clingy."
    },
    {
      "type": "range",
      "id": "delay_seconds",
      "label": "Delay before showing (seconds)",
      "min": 1,
      "max": 30,
      "step": 1,
      "default": 5
    },
    {
      "type": "range",
      "id": "cookie_days",
      "label": "Days before showing again",
      "min": 1,
      "max": 90,
      "step": 1,
      "default": 30
    }
  ],
  "presets": [
    {
      "name": "Email Popup"
    }
  ]
}
{% endschema %}

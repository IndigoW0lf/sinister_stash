{% comment %}
  Sinister Stash — Shop By Category
  Visual collection grid for homepage navigation.
  Each block is a category card with image, title, and link.
{% endcomment %}

<div class="sg-shop-by color-{{ section.settings.color_scheme }}">
  <div class="sg-shop-by__inner page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="sg-shop-by__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subhead != blank -%}
      <p class="sg-shop-by__subhead">{{ section.settings.subhead }}</p>
    {%- endif -%}

    <div class="sg-shop-by__grid sg-shop-by__grid--{{ section.blocks.size }}">
      {%- for block in section.blocks -%}
        <a
          class="sg-shop-by__card"
          href="{{ block.settings.link | default: '#' }}"
          {{ block.shopify_attributes }}
        >
          <div class="sg-shop-by__card-image-wrap">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 800 | image_tag:
                class: 'sg-shop-by__card-image',
                loading: 'lazy',
                widths: '400, 600, 800',
                sizes: '(max-width: 749px) 50vw, 25vw'
              }}
            {%- else -%}
              <div class="sg-shop-by__card-placeholder">
                {{ 'collection-1' | placeholder_svg_tag: 'sg-shop-by__card-placeholder-svg' }}
              </div>
            {%- endif -%}
            <div class="sg-shop-by__card-overlay"></div>
          </div>
          <div class="sg-shop-by__card-content">
            <h3 class="sg-shop-by__card-title">{{ block.settings.title }}</h3>
            {%- if block.settings.subtitle != blank -%}
              <p class="sg-shop-by__card-subtitle">{{ block.settings.subtitle }}</p>
            {%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Shop By Category",
  "class": "sg-shop-by-section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SHOP THE STASH"
    },
    {
      "type": "text",
      "id": "subhead",
      "label": "Subhead"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Category"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop By Category",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "title": "APPAREL"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "STICKERS"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "PATCHES"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "RANGE GEAR"
          }
        }
      ]
    }
  ]
}
{% endschema %}

{% comment %}
  SINISTER STASH — Custom Blog Article Template
  File: sections/article.sinister.liquid
  Paired with: assets/sinister-stash.css (blog section)
  Drop this file in your theme's sections/ folder.
  On each blog post, select "sinister" from the Theme template dropdown.
{% endcomment %}

<article class="ss-article" itemscope itemtype="http://schema.org/BlogPosting">

  {%- assign blog_handle = article.blog.handle -%}

  <!-- POST HEADER -->
  <header class="ss-article__header">
    <div class="ss-article__header-inner">
      {%- if article.tags.size > 0 -%}
        <div class="ss-article__category">
          {{ article.tags | first | upcase }}
        </div>
      {%- endif -%}

      <h1 class="ss-article__title" itemprop="headline">
        {{ article.title }}
      </h1>

      <div class="ss-article__meta">
        <span>Sinister Stash</span>
        <span class="ss-article__meta-sep">·</span>
        <span itemprop="author">{{ article.author }}</span>
        <span class="ss-article__meta-sep">·</span>
        <time itemprop="datePublished" datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
          {{ article.published_at | date: '%B %d, %Y' }}
        </time>
      </div>
    </div>
  </header>

  <!-- POST BODY -->
  <div class="ss-article__body" itemprop="articleBody">
    {{ article.content }}
  </div>

  <!-- POST FOOTER -->
  <footer class="ss-article__footer">
    <div class="ss-article__footer-inner">

      {%- if article.tags.size > 0 -%}
        <div class="ss-article__tags">
          {%- for tag in article.tags -%}
            <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="ss-article__tag">
              {{- tag -}}
            </a>
          {%- endfor -%}
        </div>
      {%- endif -%}

      <div class="ss-article__cta">
        <p>The stash is being built.<br>Start yours.</p>
        <a href="/collections/all" class="ss-article__cta-btn">Shop the Drop →</a>
      </div>

      <!-- PREV / NEXT NAV -->
      <nav class="ss-article__nav">
        {%- if blog.previous_article -%}
          <a href="{{ blog.previous_article }}" class="ss-article__nav-link ss-article__nav-link--prev">
            ← Previous
          </a>
        {%- endif -%}
        {%- if blog.next_article -%}
          <a href="{{ blog.next_article }}" class="ss-article__nav-link ss-article__nav-link--next">
            Next →
          </a>
        {%- endif -%}
      </nav>

    </div>
  </footer>

</article>

<style>
/* ============================================
   ARTICLE — SINISTER (restored)
   ============================================ */

/* ── Header ──────────────────────────────── */

.ss-article__header {
  background: #0E161B;
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  padding: 80px 24px 64px;
  text-align: center;
}

.ss-article__header-inner {
  max-width: 820px;
  margin: 0 auto;
}

.ss-article__category {
  display: inline-block;
  font-family: var(--font-body-family);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: #4AD4A8;
  margin-bottom: 28px;
}

.ss-article__title {
  font-family: var(--font-body-family);
  font-weight: 700;
  font-size: clamp(32px, 6vw, 64px);
  line-height: 1.05;
  color: #F0EDEA;
  margin: 0 auto 24px;
}

.ss-article__meta {
  font-family: var(--font-body-family);
  font-size: 13px;
  color: rgba(240, 237, 234, 0.45);
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

.ss-article__meta-sep {
  margin: 0 8px;
  opacity: 0.4;
}

/* ── Body ────────────────────────────────── */

.ss-article__body {
  max-width: 720px;
  margin: 0 auto;
  padding: 72px 24px 96px;
  font-family: var(--font-body-family);
  font-size: 18px;
  line-height: 1.75;
  color: rgba(240, 237, 234, 0.88);
}

.ss-article__body p {
  margin-bottom: 28px;
}

.ss-article__body p:first-child {
  font-size: 20px;
  color: #F0EDEA;
  line-height: 1.65;
}

.ss-article__body h2 {
  font-family: var(--font-body-family);
  font-weight: 700;
  font-size: 26px;
  color: #F0EDEA;
  margin: 56px 0 20px;
  line-height: 1.2;
}

.ss-article__body h3 {
  font-family: var(--font-body-family);
  font-weight: 700;
  font-size: 20px;
  color: #F0EDEA;
  margin: 40px 0 16px;
}

.ss-article__body a {
  color: #F0645A;
  text-decoration: underline;
  text-underline-offset: 3px;
}

.ss-article__body a:hover {
  color: #4AD4A8;
}

.ss-article__body strong {
  color: #F0EDEA;
  font-weight: 700;
}

.ss-article__body hr {
  border: none;
  border-top: 2px solid rgba(255, 255, 255, 0.12);
  margin: 48px 0;
}

.ss-article__body ul,
.ss-article__body ol {
  padding-left: 24px;
  margin-bottom: 28px;
}

.ss-article__body li {
  margin-bottom: 10px;
}

/* Pull quote / blockquote — coral left bar */
.ss-article__body blockquote,
.ss-article__body .pull-quote {
  border: none;
  border-left: 3px solid #F0645A;
  margin: 48px 0;
  padding: 8px 0 8px 32px;
  font-size: 22px;
  font-weight: 700;
  line-height: 1.35;
  color: #F0EDEA;
  font-style: normal;
}

.ss-article__body blockquote em,
.ss-article__body .pull-quote em {
  color: #F0645A;
  font-style: normal;
}

/* ── Footer ──────────────────────────────── */

.ss-article__footer {
  border-top: 1px solid rgba(255, 255, 255, 0.08);
  padding: 48px 24px 80px;
}

.ss-article__footer-inner {
  max-width: 720px;
  margin: 0 auto;
}

.ss-article__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 40px;
}

.ss-article__tag {
  font-family: var(--font-body-family);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #141E24;
  background: #F0EDEA;
  padding: 5px 12px;
  text-decoration: none;
  transition: background 0.15s ease, color 0.15s ease;
}

.ss-article__tag:hover {
  background: #F0645A;
  color: white;
}

/* CTA block — coral bg */
.ss-article__cta {
  background: #F0645A;
  padding: 40px 36px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
  flex-wrap: wrap;
  margin-bottom: 48px;
}

.ss-article__cta p {
  font-family: var(--font-body-family);
  font-weight: 700;
  font-size: 18px;
  color: white;
  margin: 0;
  line-height: 1.3;
}

.ss-article__cta-btn {
  display: inline-block;
  background: white;
  color: #F0645A;
  font-family: var(--font-body-family);
  font-weight: 700;
  font-size: 13px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  text-decoration: none;
  padding: 14px 28px;
  white-space: nowrap;
  flex-shrink: 0;
  transition: background 0.15s ease, color 0.15s ease;
}

.ss-article__cta-btn:hover {
  background: #141E24;
  color: white;
}

.ss-article__nav {
  display: flex;
  justify-content: space-between;
  gap: 16px;
}

.ss-article__nav-link {
  font-family: var(--font-body-family);
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(240, 237, 234, 0.5);
  text-decoration: none;
  transition: color 0.15s ease;
}

.ss-article__nav-link:hover {
  color: #F0645A;
}

.ss-article__nav-link--next {
  margin-left: auto;
}

@media screen and (max-width: 749px) {
  .ss-article__header {
    padding: 48px 24px 40px;
  }

  .ss-article__body {
    padding: 48px 24px 64px;
    font-size: 17px;
  }

  .ss-article__body blockquote,
  .ss-article__body .pull-quote {
    font-size: 19px;
    padding-left: 20px;
  }

  .ss-article__cta {
    flex-direction: column;
    align-items: flex-start;
  }
}
</style>

{% schema %}
{
  "name": "Sinister Article",
  "settings": []
}
{% endschema %}
